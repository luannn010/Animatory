    "ReadinessDot": "../.design-sync/groups/feedback.md",
    "ProgressBar": "../.design-sync/groups/feedback.md",
    "Card": "../.design-sync/groups/layout.md",
    "TrackHeaderStrip": "../.design-sync/groups/layout.md",
    "SectionLabel": "../.design-sync/groups/layout.md",
    "BackLink": "../.design-sync/groups/layout.md",
