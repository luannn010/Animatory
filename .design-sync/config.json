    "ReadinessDot": "src/studio/ui/primitives.tsx",
    "ProgressBar": "src/studio/ui/primitives.tsx",
    "Card": "src/studio/ui/primitives.tsx",
    "Input": "src/studio/ui/primitives.tsx",
    "Textarea": "src/studio/ui/primitives.tsx",
    "Icon": "src/studio/ui/Icon.tsx",
    "PlateThumb": "src/studio/ui/PlateThumb.tsx",
    "TrackHeaderStrip": "src/studio/ui/shell.tsx",
    "SectionLabel": "src/studio/ui/shell.tsx",
    "BackLink": "src/studio/ui/shell.tsx"
