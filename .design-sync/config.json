    "PlateThumb": "../.design-sync/groups/media.md"
  },
  "overrides": {
    "TrackHeaderStrip": { "cardMode": "column" },
    "SectionLabel": { "cardMode": "column" },
    "Textarea": { "cardMode": "column" }
