# Animatory backend configuration template.
# Copy to .env and adjust for your machine:  cp .env.example .env
# Loaded automatically at startup via python-dotenv (see animatory/__init__.py).
# Real environment variables override these values.

# --- Qwen scene-parser (llama.cpp OpenAI-compatible server) ---
QWEN_ENDPOINT=http://localhost:9000
QWEN_MODEL=Qwen3.5-4B-Q4_K_M.gguf
# QWEN_MAX_RETRIES=3
# QWEN_TIMEOUT_S=300
# Disable Qwen3.5 chain-of-thought for speed (1 = re-enable reasoning)
# QWEN_ENABLE_THINKING=0
# Two-phase parsing (segment -> per-scene extract): 1 = on, 0 = single-pass
# QWEN_TWO_PHASE=1
# QWEN_PARSE_CONCURRENCY=1   # raise only if llama-server runs with --parallel

# --- Agent registry / persistence ---
# ANIMATORY_YAML_PATH=agent-framework.yaml
# DB_PATH=animatory.db          # use :memory: for in-memory mode
# ANIMATORY_FAKE_EXECUTORS=0    # set to 1 to run without GPU/llama.cpp

# --- ComfyUI adaptor ---
# COMFYUI_ENDPOINT=http://localhost:8188
# COMFYUI_POLL_INTERVAL_S=2.0

# --- llama.cpp text executor ---
# LLAMACPP_ENDPOINT=http://localhost:8080
# LLAMACPP_MODEL=local
# LLAMACPP_CONTEXT_LENGTH=4096

# --- CORS ---
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
